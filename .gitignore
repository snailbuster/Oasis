# ============================================================
# Unity .gitignore （官方推荐 + 常见扩展）
# ============================================================

# Unity 自动生成 / 缓存目录（不入库）
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# 资源 Asset 临时
[Aa]ssets/AssetStoreTools*
[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio / Rider / VSCode
.vs/
.vscode/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity Build 产物
*.apk
*.aab
*.unitypackage
*.app

# 崩溃 dump / 临时
crashlytics-build.properties
sysinfo.txt
*.bak

# OS
.DS_Store
Thumbs.db
desktop.ini
