# Auto detect text files
* text=auto eol=lf

# Force LF for code
*.cs text eol=lf
*.shader text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Unity YAML 资源 — 视为文本，便于 diff
*.meta text merge=unityyamlmerge eol=lf
*.unity text merge=unityyamlmerge eol=lf
*.asset text merge=unityyamlmerge eol=lf
*.prefab text merge=unityyamlmerge eol=lf
*.mat text merge=unityyamlmerge eol=lf
*.anim text merge=unityyamlmerge eol=lf
*.controller text merge=unityyamlmerge eol=lf
*.physicMaterial text merge=unityyamlmerge eol=lf
*.physicsMaterial2D text merge=unityyamlmerge eol=lf

# 二进制（不要 diff，不要 LF 处理）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.psd binary
*.tga binary
*.tif binary
*.tiff binary
*.bmp binary
*.exr binary
*.hdr binary
*.fbx binary
*.obj binary
*.blend binary
*.dae binary
*.3ds binary
*.dds binary
*.wav binary
*.mp3 binary
*.ogg binary
*.flac binary
*.mp4 binary
*.mov binary
*.unitypackage binary
*.dll binary
*.pdb binary
*.so binary
*.dylib binary
*.bundle binary
*.ttf binary
*.otf binary
